# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Fernet encryption key for user API keys at rest.
# Generate ONCE via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DO NOT change after deploy — existing encrypted keys will become unreadable.
ENCRYPTION_KEY=paste_your_fernet_key_here

# PostgreSQL (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://botuser:botpass@localhost:5432/telegrambot

# Bot mode
BOT_MODE=polling
WEBHOOK_URL=
WEBHOOK_PORT=8443

# Timezone for reminders
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh

# (Optional) override model names
# LLM_TIER1=gemini-2.5-flash-lite-preview-06-17
# LLM_TIER2=gemini-2.5-flash
# LLM_TIER3=gemini-2.5-pro
# LLM_TIER4=llama-3.3-70b-versatile
