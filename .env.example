# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# AI Providers (free tier)
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Optional: override default model names
# MODEL_TIER1=gemini-2.5-flash-lite-preview-06-17
# MODEL_TIER2=gemini-2.5-flash
# MODEL_TIER3=gemini-2.5-pro
# MODEL_TIER4=llama-3.3-70b-versatile

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://botuser:botpass@localhost:5432/telegrambot

# Bot settings
BOT_MODE=polling  # polling | webhook
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_PORT=8443

# APScheduler
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
